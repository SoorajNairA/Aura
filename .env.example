# AURA local configuration template.
# Copy to .env and customize. Do not commit .env.

# Conversation brain
AURA_CONVERSATION_BACKEND=ollama
AURA_OLLAMA_BASE_URL=http://localhost:11434
AURA_OLLAMA_MODEL=qwen2.5:14b
AURA_OLLAMA_TIMEOUT=120
AURA_OLLAMA_CONTEXT_LENGTH=32768

# Speech-to-text
AURA_STT_MODEL=small
AURA_STT_DEVICE=cpu
AURA_STT_COMPUTE_TYPE=int8

# Text-to-speech
AURA_TTS_BACKEND=xtts
AURA_TTS_DEVICE=cuda
AURA_AUTO_WARMUP=true
AURA_VOICE_REFERENCE=voices/aura_voice.wav
AURA_TTS_CACHE_DIR=models/xtts

# Optional local fallbacks
AURA_LOCAL_TTS_RATE=155
AURA_LOCAL_TTS_VOICE_INDEX=1

# Voice input
AURA_SAMPLE_RATE=16000
AURA_MAX_RECORD_SECONDS=12
AURA_SILENCE_THRESHOLD=0.01
AURA_SILENCE_HOLD_SECONDS=1.2
AURA_WAKE_WORD=aura

# Runtime storage
AURA_MEMORY_DIR=memory
AURA_LOG_DIR=logs
AUTO_REVEAL_RESULTS=true

# Safety confirmation
AURA_CONFIRM_WORDS=yes,confirm,proceed
AURA_REJECT_WORDS=no,stop,cancel
